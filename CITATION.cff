    given-names: "Félix E."
    name-suffix: "PhD FAAAAI"
    orcid: "https://orcid.org/0000-0002-6671-0174"
repository-code: "https://github.com/friveramariani/SporeLag"
keywords:
  - R
  - environmental-epidemiology
  - aeroallergens
  - pollen
  - exposure-assessment
  - lag-response
version: 0.1.0
date-released: 2026-07-14
